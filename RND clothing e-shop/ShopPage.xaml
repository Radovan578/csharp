<Window x:Class="RND_clothing_e_shop.ShopPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Obchod"
        WindowState="Maximized"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#FF111111">

    <Window.Resources>

        <!-- Buttons -->
        <Style x:Key="RoundedButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="55"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Category buttons -->
        <Style x:Key="CategoryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="48"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="#FF1F1F1F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>

        <!-- Back arrow -->
        <Button Content="←"
                Width="70"
                Height="70"
                FontSize="30"
                FontWeight="Bold"
                Background="#66000000"
                Foreground="White"
                BorderThickness="0"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="25"
                Cursor="Hand"
                Click="BackButton_Click"
                Panel.ZIndex="3">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="35">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <!-- Layout -->
        <Grid Margin="40">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT PANEL -->
            <Border Grid.Column="0"
                    Background="#FF1A1A1A"
                    CornerRadius="20"
                    Padding="20"
                    Margin="0,0,20,0">

                <StackPanel>

                    <TextBlock Text="Kategórie"
                               Foreground="White"
                               FontSize="26"
                               FontWeight="Bold"
                               Margin="0,0,0,20"/>

                    <Button Content="Všetko" Style="{StaticResource CategoryButtonStyle}"/>
                    <Button Content="Tričká" Style="{StaticResource CategoryButtonStyle}"/>
                    <Button Content="Mikiny" Style="{StaticResource CategoryButtonStyle}"/>
                    <Button Content="Nohavice" Style="{StaticResource CategoryButtonStyle}"/>
                    <Button Content="Bundy" Style="{StaticResource CategoryButtonStyle}"/>

                    <Border Height="30"/>

                    <Button Content="Prejsť do košíka"
                            Style="{StaticResource RoundedButtonStyle}"
                            Background="White"
                            Foreground="Black"
                            Click="CartButton_Click"/>
                </StackPanel>
            </Border>

            <!-- RIGHT PANEL -->
            <Border Grid.Column="1"
                    Background="#FF1A1A1A"
                    CornerRadius="20"
                    Padding="20">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Obchod"
                               Foreground="White"
                               FontSize="34"
                               FontWeight="Bold"
                               Margin="0,0,0,20"/>

                    <!-- PRODUCTS -->
                    <ScrollViewer Grid.Row="1">
                        <WrapPanel>

                            <!-- PRODUCT -->
                            <Border Width="220"
                                    Height="280"
                                    Background="#FF2A2A2A"
                                    CornerRadius="15"
                                    Margin="10"
                                    Padding="10">

                                <StackPanel>

                                    <Border Height="120"
                                            Background="#FF3A3A3A"
                                            CornerRadius="10"
                                            Margin="0,0,0,10"/>

                                    <TextBlock Text="Tričko"
                                               Foreground="White"
                                               FontSize="18"
                                               FontWeight="SemiBold"/>

                                    <TextBlock Text="19,99 €"
                                               Foreground="#CCCCCC"
                                               Margin="0,5,0,10"/>

                                    <Button Content="Pridať"
                                            Style="{StaticResource RoundedButtonStyle}"
                                            Height="40"
                                            FontSize="14"
                                            Background="White"
                                            Foreground="Black"/>
                                </StackPanel>
                            </Border>

                            <!-- ďalší produkt -->
                            <Border Width="220"
                                    Height="280"
                                    Background="#FF2A2A2A"
                                    CornerRadius="15"
                                    Margin="10"
                                    Padding="10">

                                <StackPanel>

                                    <Border Height="120"
                                            Background="#FF3A3A3A"
                                            CornerRadius="10"
                                            Margin="0,0,0,10"/>

                                    <TextBlock Text="Mikina"
                                               Foreground="White"
                                               FontSize="18"
                                               FontWeight="SemiBold"/>

                                    <TextBlock Text="39,99 €"
                                               Foreground="#CCCCCC"
                                               Margin="0,5,0,10"/>

                                    <Button Content="Pridať"
                                            Style="{StaticResource RoundedButtonStyle}"
                                            Height="40"
                                            FontSize="14"
                                            Background="White"
                                            Foreground="Black"/>
                                </StackPanel>
                            </Border>

                        </WrapPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>