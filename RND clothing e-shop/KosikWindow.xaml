<Window x:Class="RND_clothing_e_shop.KosikWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Košík"
        WindowState="Maximized"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#FF111111">

    <Window.Resources>
        <Style x:Key="RoundedButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="55"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SmallButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Sipka spat -->
        <Button x:Name="BackButton"
                Content="←"
                Width="70"
                Height="70"
                FontSize="30"
                FontWeight="Bold"
                Background="#66000000"
                Foreground="White"
                BorderThickness="0"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="25"
                Cursor="Hand"
                Click="BackButton_Click"
                Panel.ZIndex="3">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="35">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <Grid Margin="40,110,40,40">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="380" />
            </Grid.ColumnDefinitions>

            <!-- Lava cast - produkty -->
            <Border Grid.Column="0"
                    Background="#FF1A1A1A"
                    CornerRadius="22"
                    Padding="25"
                    Margin="0,0,20,0">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Môj košík"
                               Foreground="White"
                               FontSize="34"
                               FontWeight="Bold"
                               Margin="0,0,0,20"/>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel>

                            <!-- Produkt 1 -->
                            <Border Background="#FF262626"
                                    CornerRadius="18"
                                    Padding="18"
                                    Margin="0,0,0,16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="170"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Miesto na obrazok -->
                                    <Border Grid.Column="0"
                                            Width="110"
                                            Height="110"
                                            Background="#FF3A3A3A"
                                            CornerRadius="14"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="Obrázok"
                                                   Foreground="#AAAAAA"
                                                   FontSize="16"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- Info -->
                                    <StackPanel Grid.Column="1"
                                                Margin="10,0,20,0"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="Biele tričko"
                                                   Foreground="White"
                                                   FontSize="22"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,0,8"/>
                                        <TextBlock Text="Cena za kus: 19,99 €"
                                                   Foreground="#DDDDDD"
                                                   FontSize="16"
                                                   Margin="0,0,0,6"/>
                                        <TextBlock Text="Veľkosť: M"
                                                   Foreground="#BBBBBB"
                                                   FontSize="15"/>
                                    </StackPanel>

                                    <!-- Mnozstvo -->
                                    <StackPanel Grid.Column="2"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Right">
                                        <TextBlock Text="Množstvo"
                                                   Foreground="White"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,0,0,8"/>
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Center">
                                            <Button Content="-"
                                                    Style="{StaticResource SmallButtonStyle}"
                                                    Click="MinusButton_Click"/>
                                            <TextBlock Text="2"
                                                       Foreground="White"
                                                       FontSize="20"
                                                       Width="40"
                                                       TextAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                            <Button Content="+"
                                                    Style="{StaticResource SmallButtonStyle}"
                                                    Click="PlusButton_Click"/>
                                        </StackPanel>

                                        <Button Content="Odstrániť"
                                                Height="42"
                                                Margin="0,14,0,0"
                                                Background="#FFB71C1C"
                                                Foreground="White"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                Click="RemoveItem_Click">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            CornerRadius="12">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Produkt 2 -->
                            <Border Background="#FF262626"
                                    CornerRadius="18"
                                    Padding="18"
                                    Margin="0,0,0,16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="170"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Width="110"
                                            Height="110"
                                            Background="#FF3A3A3A"
                                            CornerRadius="14"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="Obrázok"
                                                   Foreground="#AAAAAA"
                                                   FontSize="16"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>

                                    <StackPanel Grid.Column="1"
                                                Margin="10,0,20,0"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="Čierna mikina"
                                                   Foreground="White"
                                                   FontSize="22"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,0,8"/>
                                        <TextBlock Text="Cena za kus: 39,99 €"
                                                   Foreground="#DDDDDD"
                                                   FontSize="16"
                                                   Margin="0,0,0,6"/>
                                        <TextBlock Text="Veľkosť: L"
                                                   Foreground="#BBBBBB"
                                                   FontSize="15"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Right">
                                        <TextBlock Text="Množstvo"
                                                   Foreground="White"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,0,0,8"/>
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Center">
                                            <Button Content="-"
                                                    Style="{StaticResource SmallButtonStyle}"
                                                    Click="MinusButton_Click"/>
                                            <TextBlock Text="1"
                                                       Foreground="White"
                                                       FontSize="20"
                                                       Width="40"
                                                       TextAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                            <Button Content="+"
                                                    Style="{StaticResource SmallButtonStyle}"
                                                    Click="PlusButton_Click"/>
                                        </StackPanel>

                                        <Button Content="Odstrániť"
                                                Height="42"
                                                Margin="0,14,0,0"
                                                Background="#FFB71C1C"
                                                Foreground="White"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                Click="RemoveItem_Click">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            CornerRadius="12">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Prava cast - sumar -->
            <Border Grid.Column="1"
                    Background="#FF1A1A1A"
                    CornerRadius="22"
                    Padding="25">

                <StackPanel>
                    <TextBlock Text="Zhrnutie objednávky"
                               Foreground="White"
                               FontSize="28"
                               FontWeight="Bold"
                               Margin="0,0,0,25"/>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Počet produktov"
                                   Foreground="#DDDDDD"
                                   FontSize="18"/>
                        <TextBlock Grid.Column="1"
                                   Text="3"
                                   Foreground="White"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>
                    </Grid>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Doprava"
                                   Foreground="#DDDDDD"
                                   FontSize="18"/>
                        <TextBlock Grid.Column="1"
                                   Text="4,99 €"
                                   Foreground="White"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>
                    </Grid>

                    <Separator Margin="0,10,0,20" Background="#555555"/>

                    <Grid Margin="0,0,0,30">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Celkom"
                                   Foreground="White"
                                   FontSize="24"
                                   FontWeight="Bold"/>
                        <TextBlock Grid.Column="1"
                                   Text="84,97 €"
                                   Foreground="White"
                                   FontSize="24"
                                   FontWeight="Bold"/>
                    </Grid>

                    <Button x:Name="OrderButton"
                            Content="Dokončiť objednávku"
                            Style="{StaticResource RoundedButtonStyle}"
                            Background="White"
                            Foreground="Black"
                            Margin="0,0,0,14"
                            Click="OrderButton_Click"/>

                    <Button x:Name="ContinueShoppingButton"
                            Content="Pokračovať v nákupe"
                            Style="{StaticResource RoundedButtonStyle}"
                            Background="#FF1F1F1F"
                            Foreground="White"
                            BorderBrush="White"
                            BorderThickness="2"
                            Click="ContinueShoppingButton_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>