<Window x:Class="RND_clothing_e_shop.DetailProduktu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Detail produktu"
        WindowState="Maximized"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#FF111111">

    <Window.Resources>
        <Style x:Key="RoundedButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="55"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ColorButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="21"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ComboBoxStyleModern" TargetType="ComboBox">
            <Setter Property="Height" Value="45"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Background" Value="#FFF2F2F2"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Margin" Value="0,8,0,20"/>
            <Setter Property="Padding" Value="10,5"/>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Sipka spat -->
        <Button x:Name="BackButton"
                Content="←"
                Width="70"
                Height="70"
                FontSize="30"
                FontWeight="Bold"
                Background="#66000000"
                Foreground="White"
                BorderThickness="0"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="25"
                Cursor="Hand"
                Click="BackButton_Click"
                Panel.ZIndex="3">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="35">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <Grid Margin="50,110,50,50">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*" />
                <ColumnDefinition Width="0.9*" />
            </Grid.ColumnDefinitions>

            <!-- Lava strana - obrazok -->
            <Border Grid.Column="0"
                    Background="#FF1A1A1A"
                    CornerRadius="25"
                    Margin="0,0,20,0"
                    Padding="25">
                <Grid>
                    <Border Background="#FF2A2A2A"
                            CornerRadius="20"
                            Padding="20">

                        <Grid>
                            <Image x:Name="ProductImage"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>

                            <!-- Toto je len pomocny text, kym nenastavis obrazok -->
                            <TextBlock x:Name="ProductImagePlaceholder"
                                       Text="Obrázok produktu"
                                       Foreground="#888888"
                                       FontSize="24"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- Prava strana - info -->
            <Border Grid.Column="1"
                    Background="#FF1A1A1A"
                    CornerRadius="25"
                    Padding="30">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Background="Transparent">
                    <StackPanel>

                        <TextBlock x:Name="ProductNameText"
                                   Text="Čierna mikina"
                                   Foreground="White"
                                   FontSize="36"
                                   FontWeight="Bold"
                                   Margin="0,0,0,14"/>

                        <TextBlock x:Name="ProductPriceText"
                                   Text="39,99 €"
                                   Foreground="#DDDDDD"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,25"/>

                        <TextBlock Text="Popis produktu"
                                   Foreground="White"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,10"/>

                        <TextBlock x:Name="ProductDescriptionText"
                                   TextWrapping="Wrap"
                                   Foreground="#DDDDDD"
                                   FontSize="16"
                                   LineHeight="28"
                                   Margin="0,0,0,28"
                                   Text="Moderná mikina z príjemného materiálu vhodná na každodenné nosenie. Má pohodlný strih, kvalitné spracovanie a hodí sa ku jeansom aj teplákom."/>

                        <TextBlock Text="Farba"
                                   Foreground="White"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,12"/>

                        <StackPanel Orientation="Horizontal"
                                    Margin="0,0,0,25">
                            <Button x:Name="BlackColorButton"
                                    Background="Black"
                                    Style="{StaticResource ColorButtonStyle}"
                                    Click="BlackColorButton_Click"/>

                            <Button x:Name="WhiteColorButton"
                                    Background="White"
                                    Style="{StaticResource ColorButtonStyle}"
                                    Click="WhiteColorButton_Click"/>

                            <Button x:Name="GrayColorButton"
                                    Background="Gray"
                                    Style="{StaticResource ColorButtonStyle}"
                                    Click="GrayColorButton_Click"/>

                            <Button x:Name="BlueColorButton"
                                    Background="#FF2D5BFF"
                                    Style="{StaticResource ColorButtonStyle}"
                                    Click="BlueColorButton_Click"/>
                        </StackPanel>

                        <TextBlock Text="Veľkosť"
                                   Foreground="White"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8"/>

                        <ComboBox x:Name="SizeComboBox"
                                  Style="{StaticResource ComboBoxStyleModern}">
                            <ComboBoxItem Content="S"/>
                            <ComboBoxItem Content="M"/>
                            <ComboBoxItem Content="L"/>
                            <ComboBoxItem Content="XL"/>
                        </ComboBox>

                        <TextBlock Text="Množstvo"
                                   Foreground="White"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8"/>

                        <StackPanel Orientation="Horizontal"
                                    Margin="0,0,0,30">
                            <Button Content="-"
                                    Width="45"
                                    Height="45"
                                    FontSize="22"
                                    FontWeight="Bold"
                                    Background="White"
                                    Foreground="Black"
                                    BorderThickness="0"
                                    Click="MinusButton_Click"/>

                            <TextBlock x:Name="QuantityText"
                                       Text="1"
                                       Width="50"
                                       Foreground="White"
                                       FontSize="22"
                                       TextAlignment="Center"
                                       VerticalAlignment="Center"/>

                            <Button Content="+"
                                    Width="45"
                                    Height="45"
                                    FontSize="22"
                                    FontWeight="Bold"
                                    Background="White"
                                    Foreground="Black"
                                    BorderThickness="0"
                                    Click="PlusButton_Click"/>
                        </StackPanel>

                        <Button x:Name="AddToCartButton"
                                Content="Pridať do košíka"
                                Style="{StaticResource RoundedButtonStyle}"
                                Background="White"
                                Foreground="Black"
                                Margin="0,0,0,14"
                                Click="AddToCartButton_Click"/>

                        <Button x:Name="BuyNowButton"
                                Content="Kúpiť hneď"
                                Style="{StaticResource RoundedButtonStyle}"
                                Background="#FF1F1F1F"
                                Foreground="White"
                                BorderBrush="White"
                                BorderThickness="2"
                                Click="BuyNowButton_Click"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>