<Window x:Class="MiniEdupage.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MiniEdupage"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <TextBox Name="AddZiakTextBox" HorizontalAlignment="Left" Margin="58,74,0,0" TextWrapping="Wrap" Text="Zadaj meno ziaka..." VerticalAlignment="Top" Width="120" TextChanged="AddZiak_TextChanged" GotFocus="AddZiakTextBox_GotFocus" LostFocus="AddZiakTextBox_LostFocus"/>
        <Button Content="Pridat ziaka" HorizontalAlignment="Left" Margin="211,66,0,0" VerticalAlignment="Top" Width="107" Height="34" Click="AddZiakButton_Click"/>
        <TextBlock HorizontalAlignment="Left" Margin="58,29,0,0" TextWrapping="Wrap" Text="Pridanie ziaka" VerticalAlignment="Top" Width="120"/>
        <TextBlock Text="Zoznam žiakov" HorizontalAlignment="Left" Margin="58,110,0,0" VerticalAlignment="Top" FontWeight="Bold"/>
        <ListBox Name="ZiaciListBox" Margin="58,135,530,90" SelectionChanged="ZiaciListBox_SelectionChanged" DisplayMemberPath="Name"/>
        <Label Content="Meno žiaka:" HorizontalAlignment="Left" Margin="310,135,0,0" VerticalAlignment="Top" FontWeight="Bold"/>
        <TextBlock Name="MenoZiakaTextBlock" HorizontalAlignment="Left" Margin="400,140,0,0" VerticalAlignment="Top" Text="-"/>

        <Label Content="Pridať známku:" HorizontalAlignment="Left" Margin="310,175,0,0" VerticalAlignment="Top"/>
        <ComboBox Name="ZnamkaComboBox" HorizontalAlignment="Left" Margin="410,178,0,0" VerticalAlignment="Top" Width="50">
            <ComboBoxItem Content="1" IsSelected="True"/>
            <ComboBoxItem Content="2"/>
            <ComboBoxItem Content="3"/>
            <ComboBoxItem Content="4"/>
            <ComboBoxItem Content="5"/>
        </ComboBox>
        <Button Content="Pridať známku" HorizontalAlignment="Left" Margin="475,178,0,0" VerticalAlignment="Top" Width="90" Click="PridatZnamku_Click"/>

        <Label Content="Zoznam známok:" HorizontalAlignment="Left" Margin="310,215,0,0" VerticalAlignment="Top"/>
        <TextBlock Name="ZnamkyTextBlock" HorizontalAlignment="Left" Margin="420,220,0,0" VerticalAlignment="Top" Text="-"/>

        <Label Content="Počet známok:" HorizontalAlignment="Left" Margin="310,250,0,0" VerticalAlignment="Top"/>
        <TextBlock Name="PocetZnamokTextBlock" HorizontalAlignment="Left" Margin="420,255,0,0" VerticalAlignment="Top" Text="0"/>

        <Label Content="Priemerná známka:" HorizontalAlignment="Left" Margin="310,290,0,0" VerticalAlignment="Top" FontWeight="Bold"/>
        <TextBlock Name="PriemerTextBlock" HorizontalAlignment="Left" Margin="435,295,0,0" VerticalAlignment="Top" Text="0.00" FontSize="16" Foreground="Green" FontWeight="Bold"/>

        <Button Content="Vygenerovať report" HorizontalAlignment="Right" Margin="0,50,58,0" VerticalAlignment="Top" Width="160" Height="35" Background="Green" Foreground="White" Click="VygenerovatReport_Click"/>
        <Button Content="Uložiť dáta do súboru" HorizontalAlignment="Left" Margin="587,0,0,46" VerticalAlignment="Bottom" Width="150" Height="25" Click="UlozitData_Click"/>
        <Button Content="Odstrániť žiaka" 
        HorizontalAlignment="Left" 
        Margin="58,350,0,0" 
        VerticalAlignment="Top" 
        Width="150" 
        Height="30" 
        Background="Red" 
        Foreground="White" 
        FontWeight="Bold" 
        Click="OdstranitZiakButton_Click"/>
        <Label Content="Label" HorizontalAlignment="Left" Margin="-52,-40,0,0" VerticalAlignment="Top"/>
    </Grid>
</Window>
